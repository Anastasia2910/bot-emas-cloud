    elif c1 < o1 and abs(c2-o2) < abs(c1-o1) and c3 < o3: pola_kandil = "🟥 DROP BASE DROP"
    elif c1 < o1 and abs(c2-o2) < abs(c1-o1) and c3 > o3: pola_kandil = "🚀 DROP BASE RALLY"
