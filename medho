def cek_momen_trading_cloud():
    df = ambil_data_xau()
    if df is None or df.empty:
        return "Gagal mengambil data market", 500

    harga_sekarang = df['Close'].iloc[-1]
    rsi_now = RSIIndicator(close=df['Close'], window=14).rsi().iloc[-1]
    
    supply_zone_atas = df['High'].iloc[-20:].max()
    demand_zone_bawah = df['Low'].iloc[-20:].min()
    harga_wajar = (harga_sekarang + supply_zone_atas + demand_zone_bawah) / 3

    if harga_sekarang > harga_wajar and rsi_now > 50:
        tren_status = "📈 BULLISH (Tren Naik Kuat)"
    elif harga_sekarang < harga_wajar and rsi_now < 50:
        tren_status = "📉 BEARISH (Tren Turun Kuat)"
    else:
        tren_status = "📉 SIDEWAYS (Pasar Datar/Saitwei)"

    vol_sekarang = df['Volume'].iloc[-1]
    vol_rata_rata = df['Volume'].mean()
    status_vol = "🔥 TINGGI" if vol_sekarang > vol_rata_rata else "⏳ RENDAH"

    c1, c2, c3 = df['Close'].iloc[-3], df['Close'].iloc[-2], df['Close'].iloc[-1]
