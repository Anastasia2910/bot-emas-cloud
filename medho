def ambil_data_xau():
    """Mengambil data chart historis XAU/USD (Gold) untuk dianalisis"""
    url_alt = "https://query1.finance.yahoo.com/v8/finance/chart/GC=F?interval=15m&range=5d"
    headers = {'User-Agent': 'Mozilla/5.0'}
    try:
        response = requests.get(url_alt, headers=headers, timeout=10)
        if response.status_code == 200:
            json_data = response.json()
            result = json_data['chart']['result'][0]
            timestamps = result['timestamp']
            quote = result['indicators']['quote'][0]
            return pd.DataFrame({
                'Waktu': pd.to_datetime(timestamps, unit='s'),
                'Open': quote['open'], 'High': quote['high'],
                'Low': quote['low'], 'Close': quote['close'], 'Volume': quote['volume']
            }).dropna()
    except:
        pass
    return None

def ambil_berita_global():
    """Mengambil berita ekonomi makro & forex setara Investing.com"""
    url = "https://www.forexlive.com/rss/news"
    headers = {'User-Agent': 'Mozilla/5.0'}
    hasil_berita = []
    try:
        response = requests.get(url, headers=headers, timeout=10)
        if response.status_code == 200:
            root = ET.fromstring(response.content)
            for item in root.findall('.//item')[:2]:
                title = item.find('title').text
                txt = title.lower()
                sentimen = "🟢 POSITIF (Gold Naik)" if any(x in txt for x in ['fed rate cut', 'inflation', 'gold rise', 'weak dollar']) else "🔴 NEGATIF (Gold Turun)"
                hasil_berita.append(f"• **{title}**\n  *Sentimen Pasar: {sentimen}*")
            return hasil_berita
    except:
        pass
    return ["• Berita Utama: Menunggu sentimen data ekonomi besar AS.\n  *Sentimen: 🟡 NETRAL*"]

# RUTE UTAMA: Ini yang akan dipanggil oleh Alarm Otomatis luar setiap beberapa menit
@app.route('/')
